# Email Configuration
# Set SEND_REAL_EMAILS=true to actually send emails (otherwise they are just logged)
SEND_REAL_EMAILS=false

# SMTP Configuration (for Gmail, use App Password not your regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@kanatamusic.com
SMTP_FROM_NAME=Kanata Music Academy
